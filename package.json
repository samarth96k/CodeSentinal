{
  "name": "codesentinal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "wiki:init": "npm run build && node dist/wiki/initWikiCli.js",
    "wiki:update": "npm run build && node dist/wiki/updateWikiCli.js",
    "package": "npm run build && ncc build dist/index.js -o action-dist --license licenses.txt"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@vercel/ncc": "^0.38.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@google/genai": "^2.1.0",
    "dotenv": "^17.4.2",
    "octokit": "^5.0.5",
    "openai": "^6.37.0",
    "parse-diff": "^0.12.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  }
}
